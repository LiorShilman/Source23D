<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Primary Background -->
    <Color x:Key="BgPrimary">#0D0E14</Color>
    <Color x:Key="BgSurface">#13151F</Color>
    <Color x:Key="BgCard">#1A1D2E</Color>
    <Color x:Key="BgHover">#22263A</Color>

    <!-- Accent Colors -->
    <Color x:Key="AccentCyan">#00D4FF</Color>
    <Color x:Key="AccentGold">#FFB800</Color>
    <Color x:Key="AccentPurple">#9B59FF</Color>
    <Color x:Key="AccentGreen">#00FF9C</Color>
    <Color x:Key="AccentRed">#FF4C6A</Color>

    <!-- Text Colors -->
    <Color x:Key="TextPrimary">#E8EAFF</Color>
    <Color x:Key="TextSecondary">#8892AA</Color>
    <Color x:Key="TextMuted">#4A5066</Color>

    <!-- Glass / Glow -->
    <Color x:Key="GlassBase">#1E2235</Color>
    <Color x:Key="GlassBorder">#2A3050</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BgPrimaryBrush" Color="{StaticResource BgPrimary}" />
    <SolidColorBrush x:Key="BgSurfaceBrush" Color="{StaticResource BgSurface}" />
    <SolidColorBrush x:Key="BgCardBrush" Color="{StaticResource BgCard}" />
    <SolidColorBrush x:Key="BgHoverBrush" Color="{StaticResource BgHover}" />

    <SolidColorBrush x:Key="AccentCyanBrush" Color="{StaticResource AccentCyan}" />
    <SolidColorBrush x:Key="AccentGoldBrush" Color="{StaticResource AccentGold}" />
    <SolidColorBrush x:Key="AccentPurpleBrush" Color="{StaticResource AccentPurple}" />
    <SolidColorBrush x:Key="AccentGreenBrush" Color="{StaticResource AccentGreen}" />
    <SolidColorBrush x:Key="AccentRedBrush" Color="{StaticResource AccentRed}" />

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}" />

    <SolidColorBrush x:Key="GlassBaseBrush" Color="{StaticResource GlassBase}" />
    <SolidColorBrush x:Key="GlassBorderBrush" Color="{StaticResource GlassBorder}" />

    <SolidColorBrush x:Key="BorderBrush" Color="#2A3050" />

</ResourceDictionary>
