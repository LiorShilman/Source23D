<UserControl x:Class="CodeFlow3D.Views.ProjectExplorerPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CodeFlow3D.ViewModels"
             Background="{StaticResource BgSurfaceBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="160" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="10,8" BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="0,0,0,1">
            <TextBlock Text="Project Explorer" Style="{StaticResource SubHeaderText}" />
        </Border>

        <!-- Search -->
        <Border Grid.Row="1" Padding="8,6">
            <TextBox Style="{StaticResource DarkTextBox}"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=150}" />
        </Border>

        <!-- File Tree -->
        <TreeView Grid.Row="2" ItemsSource="{Binding FileTree}" Margin="4,0"
                  SelectedItemChanged="TreeView_SelectedItemChanged">
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate DataType="{x:Type vm:FileTreeNode}" ItemsSource="{Binding Children}">
                    <StackPanel Orientation="Horizontal" Margin="2,1">
                        <TextBlock Text="{Binding Icon}" Margin="0,0,6,0" FontSize="12" />
                        <TextBlock Text="{Binding Name}" Style="{StaticResource BodyText}" />
                    </StackPanel>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>

        <!-- Separator -->
        <Border Grid.Row="3" Padding="10,6" BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="0,1,0,0">
            <TextBlock Text="Functions" Style="{StaticResource SubHeaderText}" />
        </Border>

        <!-- Functions List -->
        <ListBox Grid.Row="4" ItemsSource="{Binding AllFunctions}" Background="Transparent" BorderThickness="0"
                 Foreground="{StaticResource TextPrimaryBrush}" Margin="4,0"
                 SelectedItem="{Binding SelectedSymbolCommand.Parameter, Mode=OneWayToSource}"
                 SelectionChanged="FunctionList_SelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="2,1">
                        <TextBlock Text="f" FontFamily="{StaticResource MonoFont}" Foreground="{StaticResource AccentPurpleBrush}"
                                   FontWeight="Bold" Margin="0,0,6,0" FontSize="10" />
                        <TextBlock Text="{Binding DisplayName}" Style="{StaticResource BodyText}" FontSize="11" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Stats -->
        <Border Grid.Row="4" VerticalAlignment="Bottom" Padding="8,4" Background="{StaticResource BgCardBrush}">
            <TextBlock Text="{Binding ProjectStats}" Style="{StaticResource MutedText}" TextWrapping="Wrap" />
        </Border>
    </Grid>
</UserControl>
