<UserControl x:Class="CodeFlow3D.Views.ProjectExplorerPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CodeFlow3D.ViewModels"
             Background="{StaticResource BgSurfaceBrush}">

    <UserControl.Resources>

        <!-- ── Tree expand/collapse arrow ──────────────────────────── -->
        <Style x:Key="TreeExpandToggle" TargetType="ToggleButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Width"     Value="16"/>
            <Setter Property="Height"    Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="Transparent">
                            <TextBlock x:Name="Arrow" Text="▶" FontSize="7"
                                       Foreground="#405888"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Arrow" Property="Text"       Value="▼"/>
                                <Setter TargetName="Arrow" Property="Foreground" Value="#6088C0"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Arrow" Property="Foreground" Value="#00C8E8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Dark context menu container ────────────────────────── -->
        <Style x:Key="DarkContextMenu" TargetType="ContextMenu">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="#0D1020"
                                BorderBrush="#1E2A4A"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="0,3">
                            <ItemsPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Dark menu item ──────────────────────────────────────── -->
        <Style x:Key="DarkMenuItem" TargetType="MenuItem">
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="Padding"     Value="14,7,28,7"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header" RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E3464"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#405070"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Dark separator ──────────────────────────────────────── -->
        <Style x:Key="DarkSeparator" TargetType="Separator">
            <Setter Property="Margin" Value="6,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Height="1" Background="#1A2844"
                                Margin="{TemplateBinding Margin}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="160" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="10,8" BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="0,0,0,1">
            <TextBlock Text="Project Explorer" Style="{StaticResource SubHeaderText}" />
        </Border>

        <!-- Search -->
        <Border Grid.Row="1" Padding="8,6">
            <TextBox Style="{StaticResource DarkTextBox}"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=150}" />
        </Border>

        <!-- File Tree -->
        <TreeView Grid.Row="2" x:Name="FileTreeView"
                  ItemsSource="{Binding FileTree}" Margin="4,0"
                  Background="Transparent" BorderThickness="0"
                  SelectedItemChanged="TreeView_SelectedItemChanged">

            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem">
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                    <Setter Property="Foreground"  Value="#C0C8E0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TreeViewItem">
                                <StackPanel>
                                    <!-- Header row -->
                                    <Border x:Name="Bd"
                                            Background="Transparent"
                                            BorderThickness="2,0,0,0"
                                            BorderBrush="Transparent"
                                            Padding="0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="16"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <ToggleButton Grid.Column="0" x:Name="Expander"
                                                          Style="{StaticResource TreeExpandToggle}"
                                                          IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                          ClickMode="Press"/>
                                            <ContentPresenter Grid.Column="1" ContentSource="Header"
                                                              HorizontalAlignment="Stretch"/>
                                        </Grid>
                                    </Border>
                                    <!-- Children -->
                                    <ItemsPresenter x:Name="ItemsHost" Margin="16,0,0,0"/>
                                </StackPanel>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="HasItems" Value="False">
                                        <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                                    </Trigger>
                                    <Trigger Property="IsExpanded" Value="False">
                                        <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#0F1A2E"/>
                                    </Trigger>
                                    <!-- Revealed by simulator / source / target (lower priority than selection) -->
                                    <DataTrigger Binding="{Binding IsRevealed}" Value="True">
                                        <Setter TargetName="Bd" Property="Background"  Value="#0E1E30"/>
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#007090"/>
                                    </DataTrigger>
                                    <!-- Active selection (overrides revealed) -->
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="Background"   Value="#1A2A4A"/>
                                        <Setter TargetName="Bd" Property="BorderBrush"  Value="#00C8E8"/>
                                    </Trigger>
                                    <!-- Inactive selection (focus moved elsewhere) -->
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsSelected"        Value="True"/>
                                            <Condition Property="IsSelectionActive" Value="False"/>
                                        </MultiTrigger.Conditions>
                                        <Setter TargetName="Bd" Property="Background"  Value="#141E30"/>
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#243050"/>
                                    </MultiTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TreeView.ItemContainerStyle>

            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate DataType="{x:Type vm:FileTreeNode}" ItemsSource="{Binding Children}">
                    <StackPanel Orientation="Horizontal" Margin="2,1">
                        <TextBlock Text="{Binding Icon}" Margin="0,0,6,0" FontSize="12" />
                        <TextBlock Text="{Binding Name}" Style="{StaticResource BodyText}" />
                    </StackPanel>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>

        <!-- Separator -->
        <Border Grid.Row="3" Padding="10,6" BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Functions" Style="{StaticResource SubHeaderText}" />
                <TextBlock Text="{Binding FilteredFileName}" Style="{StaticResource MutedText}"
                           FontSize="10" VerticalAlignment="Center" Margin="6,0,0,0" />
            </StackPanel>
        </Border>

        <!-- Functions List -->
        <ListBox Grid.Row="4" ItemsSource="{Binding AllFunctions}" Background="Transparent" BorderThickness="0"
                 Foreground="{StaticResource TextPrimaryBrush}" Margin="4,0"
                 SelectedItem="{Binding SelectedSymbolCommand.Parameter, Mode=OneWayToSource}"
                 SelectionChanged="FunctionList_SelectionChanged"
                 MouseRightButtonUp="FunctionList_RightClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="2,1">
                        <TextBlock Text="f" FontFamily="{StaticResource MonoFont}" Foreground="{StaticResource AccentPurpleBrush}"
                                   FontWeight="Bold" Margin="0,0,6,0" FontSize="10" />
                        <TextBlock Text="{Binding DisplayName}" Style="{StaticResource BodyText}" FontSize="11" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Padding"    Value="0" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                        BorderThickness="2,0,0,0"
                                        BorderBrush="Transparent"
                                        Padding="4,1">
                                    <ContentPresenter />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#0F1A2E" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#1A2A4A" />
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#00C8E8" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <!-- Stats -->
        <Border Grid.Row="4" VerticalAlignment="Bottom" Padding="8,4" Background="{StaticResource BgCardBrush}">
            <TextBlock Text="{Binding ProjectStats}" Style="{StaticResource MutedText}" TextWrapping="Wrap" />
        </Border>
    </Grid>
</UserControl>
