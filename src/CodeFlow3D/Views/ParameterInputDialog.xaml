<Window x:Class="CodeFlow3D.Views.ParameterInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Simulate Function — Enter Parameters"
        Width="500" Height="Auto" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0D0F1A"
        Foreground="#D0D8F0">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="Foreground" Value="#D0D8F0" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#161828" />
            <Setter Property="Foreground" Value="#00E5FF" />
            <Setter Property="BorderBrush" Value="#2A3050" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="CaretBrush" Value="#00E5FF" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="20,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <StackPanel Margin="24">
        <!-- Header -->
        <TextBlock x:Name="FunctionNameBlock"
                   FontSize="15" FontWeight="SemiBold"
                   Foreground="#00E5FF" Margin="0,0,0,4" />
        <TextBlock Text="Enter example parameter values for simulation:"
                   FontSize="11" Foreground="#6070A0" Margin="0,0,0,20" />

        <!-- Parameter rows (populated in code-behind) -->
        <ItemsControl x:Name="ParamsHost">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding TypeName}" FontSize="10" Foreground="#6070A0" />
                            <TextBlock Text="{Binding Name}" FontSize="13" Foreground="#D0D8F0" />
                        </StackPanel>
                        <TextBox Grid.Column="1"
                                 Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalAlignment="Center" />
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- No-param notice -->
        <TextBlock x:Name="NoParamsBlock"
                   Text="This function has no parameters. Click Simulate to start."
                   FontSize="12" Foreground="#6070A0"
                   Margin="0,0,0,20" Visibility="Collapsed" />

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel" IsCancel="True"
                    Background="#1A1C2E" BorderBrush="#2A3050"
                    Foreground="#8090B0" Margin="0,0,10,0"
                    Click="CancelButton_Click" />
            <Button Content="▶  Simulate" IsDefault="True"
                    Background="#004E8C" BorderBrush="#00E5FF"
                    Foreground="White" FontWeight="SemiBold"
                    Click="SimulateButton_Click" />
        </StackPanel>
    </StackPanel>
</Window>
