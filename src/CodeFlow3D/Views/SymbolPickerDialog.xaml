<Window x:Class="CodeFlow3D.Views.SymbolPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CodeFlow3D.ViewModels"
        Title="{Binding Title}"
        Width="850" Height="600"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgPrimaryBrush}"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False">

    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding CancelCommand}" />
        <KeyBinding Key="Return" Command="{Binding ConfirmCommand}" />
    </Window.InputBindings>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Search -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" Style="{StaticResource DarkTextBox}"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=150}"
                     FontSize="14" Padding="10,8"
                     x:Name="SearchBox" />
            <Button Grid.Column="1" Content="Show All" Style="{StaticResource DarkButton}"
                    Command="{Binding ClearFolderFilterCommand}" Margin="6,0,0,0" Padding="10,6"
                    FontSize="11" VerticalAlignment="Center" />
        </Grid>

        <!-- Split: folder tree + functions -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="180" />
                <ColumnDefinition Width="3" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Folder tree -->
            <Border Grid.Column="0" Background="{StaticResource BgSurfaceBrush}" CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Folders / Files" Style="{StaticResource SubHeaderText}" Margin="8,6" />
                    <TreeView Grid.Row="1" ItemsSource="{Binding FolderTree}" Background="Transparent" BorderThickness="0"
                              SelectedItemChanged="FolderTree_SelectedItemChanged">
                        <TreeView.Resources>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                <Setter Property="FontSize" Value="12" />
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                <Setter Property="Padding" Value="2,2" />
                            </Style>
                        </TreeView.Resources>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate DataType="{x:Type vm:PickerFolderNode}" ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Margin="2,1">
                                    <TextBlock Margin="0,0,5,0" FontSize="12" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="&#x1F4C1;" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsFile}" Value="True">
                                                        <Setter Property="Text" Value="&#x1F4C4;" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                    <TextBlock Foreground="{StaticResource TextMutedBrush}" FontSize="10" Margin="6,0,0,0" VerticalAlignment="Center">
                                        <Run Text="(" /><Run Text="{Binding FunctionCount, Mode=OneWay}" /><Run Text=")" />
                                    </TextBlock>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="3" Background="{StaticResource GlassBorderBrush}" />

            <!-- Symbol list -->
            <Border Grid.Column="2" Background="{StaticResource BgSurfaceBrush}" CornerRadius="4" Margin="2,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Style="{StaticResource SubHeaderText}" Margin="8,6">
                        <Run Text="Functions" />
                        <Run Text=" (" /><Run Text="{Binding FilteredSymbols.Count, Mode=OneWay}" /><Run Text=")" />
                    </TextBlock>
                    <ListBox Grid.Row="1" ItemsSource="{Binding FilteredSymbols}" SelectedItem="{Binding SelectedSymbol}"
                             Background="Transparent" Foreground="{StaticResource TextPrimaryBrush}"
                             BorderThickness="0" MouseDoubleClick="SymbolList_DoubleClick"
                             VirtualizingStackPanel.IsVirtualizing="True">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="4,3">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="f" FontFamily="{StaticResource MonoFont}" Foreground="{StaticResource AccentPurpleBrush}"
                                                   FontWeight="Bold" FontSize="10" Margin="0,0,6,0" VerticalAlignment="Center" />
                                        <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="13"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   Text="{Binding DisplayName, Mode=OneWay}" />
                                    </StackPanel>
                                    <TextBlock FontSize="10" Foreground="{StaticResource TextMutedBrush}" Margin="16,1,0,0">
                                        <Run Text="{Binding Signature, Mode=OneWay}" />
                                        <Run Text="  line " />
                                        <Run Text="{Binding LineStart, Mode=OneWay}" Foreground="{StaticResource AccentCyanBrush}" />
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <!-- Bottom: selected + confirm -->
        <DockPanel Grid.Row="2" Margin="0,8,0,0">
            <Button DockPanel.Dock="Right" Content="CONFIRM" Style="{StaticResource AccentButton}"
                    Padding="20,8" Click="Confirm_Click" IsDefault="True" />
            <Button DockPanel.Dock="Right" Content="Cancel" Style="{StaticResource DarkButton}"
                    Padding="12,8" Margin="0,0,8,0" IsCancel="True" />
            <TextBlock VerticalAlignment="Center" Style="{StaticResource BodyText}">
                <Run Text="Selected: " Foreground="{StaticResource TextSecondaryBrush}" />
                <Run Text="{Binding SelectedSymbol.DisplayName, Mode=OneWay, FallbackValue='(none)'}"
                     Foreground="{StaticResource AccentCyanBrush}" FontFamily="{StaticResource MonoFont}" />
            </TextBlock>
        </DockPanel>
    </Grid>
</Window>
