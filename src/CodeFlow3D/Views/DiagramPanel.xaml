<UserControl x:Class="CodeFlow3D.Views.DiagramPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helix="clr-namespace:HelixToolkit.Wpf;assembly=HelixToolkit.Wpf"
             Background="{StaticResource BgPrimaryBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Path tabs -->
        <Border Grid.Row="0" Padding="8,4" Background="{StaticResource BgSurfaceBrush}"
                BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="0,0,0,1"
                Visibility="{Binding Paths.Count, Converter={StaticResource CountToVisibility}}">
            <ItemsControl ItemsSource="{Binding Paths}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="10,4" Margin="2,0" CornerRadius="4" Background="{StaticResource BgCardBrush}"
                                Cursor="Hand">
                            <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}">
                                <Run Text="Path" /><Run Text=" " />
                                <Run Text="{Binding Depth, Mode=OneWay}" Foreground="{StaticResource AccentCyanBrush}" />
                                <Run Text=" steps" />
                            </TextBlock>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <!-- 3D Viewport -->
        <helix:HelixViewport3D x:Name="Viewport3D" Grid.Row="1"
                               Background="#080A10"
                               ShowCoordinateSystem="False"
                               ShowViewCube="False"
                               ZoomExtentsWhenLoaded="True"
                               IsInertiaEnabled="True"
                               InfiniteSpin="False">
            <helix:HelixViewport3D.Camera>
                <PerspectiveCamera Position="8,-8,30" LookDirection="-1,2,-20"
                                   UpDirection="0,1,0" FieldOfView="60" />
            </helix:HelixViewport3D.Camera>

            <!-- Ambient light -->
            <ModelVisual3D>
                <ModelVisual3D.Content>
                    <AmbientLight Color="#1A2030" />
                </ModelVisual3D.Content>
            </ModelVisual3D>

            <!-- Directional lights -->
            <ModelVisual3D>
                <ModelVisual3D.Content>
                    <DirectionalLight Color="#B0C8E8" Direction="-0.3,-1,-0.5" />
                </ModelVisual3D.Content>
            </ModelVisual3D>
            <ModelVisual3D>
                <ModelVisual3D.Content>
                    <DirectionalLight Color="#4060A0" Direction="0.5,0.3,-0.8" />
                </ModelVisual3D.Content>
            </ModelVisual3D>
            <ModelVisual3D>
                <ModelVisual3D.Content>
                    <DirectionalLight Color="#203050" Direction="0,-0.5,1" />
                </ModelVisual3D.Content>
            </ModelVisual3D>

            <!-- Grid floor -->
            <helix:GridLinesVisual3D x:Name="GridFloor"
                Width="60" Length="60" Thickness="0.02"
                MinorDistance="1" MajorDistance="3"
                Fill="#08FFFFFF" />

            <!-- Opaque scene (arrows, wireframes, platforms) - rendered first -->
            <helix:SortingVisual3D x:Name="OpaqueScene"
                SortingFrequency="60"
                IsSorting="True" />

            <!-- Transparent scene (glass pillars) - rendered after opaque -->
            <helix:SortingVisual3D x:Name="TransparentScene"
                SortingFrequency="60"
                IsSorting="True" />

            <!-- Dynamic lights -->
            <ModelVisual3D x:Name="DynamicLights" />
        </helix:HelixViewport3D>

        <!-- Welcome overlay -->
        <Border Grid.Row="1" x:Name="WelcomeOverlay" Background="#CC080A10"
                Visibility="{Binding CurrentLayout, Converter={StaticResource NullToVisibility}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="CodeFlow 3D" FontSize="28" FontWeight="Light"
                           Foreground="{StaticResource AccentCyanBrush}" HorizontalAlignment="Center" Margin="0,0,0,8" />
                <TextBlock Text="Open a project, select Source and Target functions, then click ANALYZE"
                           Style="{StaticResource SubHeaderText}" HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Timeline scrubber -->
        <Border Grid.Row="2" Padding="8,6" Background="{StaticResource BgSurfaceBrush}"
                BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="0,1,0,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Right" Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="8,0,0,0">
                    <Run Text="{Binding CurrentStep, Mode=OneWay}" />/<Run Text="{Binding TotalSteps, Mode=OneWay}" />
                </TextBlock>
                <Slider Minimum="0" Maximum="{Binding TotalSteps}" Value="{Binding CurrentStep}"
                        IsEnabled="{Binding TotalSteps, Converter={StaticResource IntToBool}}"
                        Foreground="{StaticResource AccentCyanBrush}" />
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
