<Window x:Class="CodeFlow3D.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:CodeFlow3D.Views"
        xmlns:conv="clr-namespace:CodeFlow3D.Converters"
        Title="CodeFlow 3D"
        Width="1400" Height="900"
        MinWidth="1000" MinHeight="600"
        Background="{StaticResource BgPrimaryBrush}"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Window.InputBindings>
        <KeyBinding Key="O" Modifiers="Ctrl" Command="{Binding OpenProjectCommand}" />
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52" />
            <RowDefinition Height="*" />
            <RowDefinition Height="28" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="{StaticResource BgSurfaceBrush}" BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Left: App title + Open + Demo -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="CodeFlow 3D" Style="{StaticResource HeaderText}" Foreground="{StaticResource AccentCyanBrush}"
                               VerticalAlignment="Center" Margin="0,0,20,0" />
                    <Button Content="Open Project" Style="{StaticResource DarkButton}" Command="{Binding OpenProjectCommand}"
                            VerticalAlignment="Center" Margin="0,0,8,0" />
                    <Button Content="Demo" Style="{StaticResource AccentButton}" Command="{Binding RunDemoCommand}"
                            VerticalAlignment="Center" Padding="14,6"
                            ToolTip="Auto-find best path in the loaded project (or load this app as demo)" />
                </StackPanel>

                <!-- Center: Source / Target / Analyze -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Source:" Style="{StaticResource BodyText}" VerticalAlignment="Center" Margin="0,0,4,0" />
                    <Button x:Name="SourceButton" Style="{StaticResource DarkButton}" MinWidth="180" Margin="0,0,12,0"
                            VerticalAlignment="Center" Click="SourceButton_Click">
                        <TextBlock Text="{Binding SourceFunction.DisplayName, FallbackValue='[Select Source...]', TargetNullValue='[Select Source...]'}"
                                   Foreground="{StaticResource AccentCyanBrush}" FontFamily="{StaticResource MonoFont}" FontSize="11" />
                    </Button>

                    <TextBlock Text="Target:" Style="{StaticResource BodyText}" VerticalAlignment="Center" Margin="0,0,4,0" />
                    <Button x:Name="TargetButton" Style="{StaticResource DarkButton}" MinWidth="180" Margin="0,0,12,0"
                            VerticalAlignment="Center" Click="TargetButton_Click">
                        <TextBlock Text="{Binding TargetFunction.DisplayName, FallbackValue='[Select Target...]', TargetNullValue='[Select Target...]'}"
                                   Foreground="{StaticResource AccentGoldBrush}" FontFamily="{StaticResource MonoFont}" FontSize="11" />
                    </Button>

                    <Button Content="ANALYZE" Style="{StaticResource AccentButton}" Command="{Binding AnalyzeFlowCommand}"
                            VerticalAlignment="Center" Padding="16,6" Margin="0,0,8,0" />

                    <Separator Background="#2A3050" Width="1" Height="20" Margin="0,0,8,0" />

                    <Button x:Name="SimulateButton" Style="{StaticResource DarkButton}"
                            VerticalAlignment="Center" Padding="14,6"
                            Click="SimulateButton_Click"
                            ToolTip="Select a function and simulate its execution step by step">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚡" FontSize="12" Margin="0,0,5,0" VerticalAlignment="Center" />
                            <TextBlock Text="SIMULATE" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold"
                                       Foreground="#FFB800" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Right: Playback -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="◀" Style="{StaticResource DarkButton}" Command="{Binding Diagram.StepBackCommand}"
                            VerticalAlignment="Center" Margin="0,0,4,0" Width="32" FontSize="12" Padding="4,6"
                            ToolTip="Step Back" />
                    <Button x:Name="PlayPauseButton" Style="{StaticResource AccentButton}"
                            VerticalAlignment="Center" Margin="0,0,4,0" Width="60" Padding="4,6"
                            Command="{Binding Diagram.TogglePlayCommand}">
                        <Button.Content>
                            <TextBlock VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="▶  Play" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Diagram.IsPlaying}" Value="True">
                                                <Setter Property="Text" Value="⏸ Pause" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button.Content>
                    </Button>
                    <Button Content="▶" Style="{StaticResource DarkButton}" Command="{Binding Diagram.StepForwardCommand}"
                            VerticalAlignment="Center" Width="32" FontSize="12" Padding="4,6"
                            ToolTip="Step Forward" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main content: 3 panels -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" MinWidth="180" />
                <ColumnDefinition Width="3" />
                <ColumnDefinition Width="*" MinWidth="300" />
                <ColumnDefinition Width="3" />
                <ColumnDefinition Width="2*" MinWidth="400" />
            </Grid.ColumnDefinitions>

            <!-- Left: Project Explorer -->
            <views:ProjectExplorerPanel Grid.Column="0" DataContext="{Binding ProjectExplorer}" />

            <GridSplitter Grid.Column="1" Width="3" />

            <!-- Center: 3D Diagram or Simulator (toggled by IsSimulatorMode) -->
            <Grid Grid.Column="2" x:Name="CenterPanel">
                <views:DiagramPanel DataContext="{Binding Diagram}"
                    Visibility="{Binding DataContext.IsSimulatorMode,
                                 RelativeSource={RelativeSource AncestorType=Window},
                                 Converter={StaticResource InvertBoolToVisibility}}" />
                <views:SimulatorPanel DataContext="{Binding Simulator}"
                    Visibility="{Binding DataContext.IsSimulatorMode,
                                 RelativeSource={RelativeSource AncestorType=Window},
                                 Converter={StaticResource BoolToVisibility}}" />

                <!-- Exit simulator button (top-right corner when in simulator mode) -->
                <Button Content="✕  Exit Simulator"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,8,8,0" Padding="10,4" FontSize="11"
                        Style="{StaticResource DarkButton}"
                        Command="{Binding ExitSimulatorCommand}"
                        Visibility="{Binding DataContext.IsSimulatorMode,
                                     RelativeSource={RelativeSource AncestorType=Window},
                                     Converter={StaticResource BoolToVisibility}}" />
            </Grid>

            <GridSplitter Grid.Column="3" Width="3" />

            <!-- Right: Code Preview -->
            <views:CodePreviewPanel Grid.Column="4" DataContext="{Binding CodePreview}" />
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="{StaticResource BgSurfaceBrush}" BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="0,1,0,0">
            <DockPanel Margin="8,0">
                <ProgressBar DockPanel.Dock="Right" Style="{StaticResource DarkProgressBar}"
                             Value="{Binding AnalysisProgress}" Width="200" Margin="8,0,0,0"
                             Visibility="{Binding IsAnalyzing, Converter={StaticResource BoolToVisibility}}" />
                <TextBlock Text="{Binding StatusText}" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
