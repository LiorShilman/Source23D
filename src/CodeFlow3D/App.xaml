<Application x:Class="CodeFlow3D.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:CodeFlow3D.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/Colors.xaml" />
                <ResourceDictionary Source="Styles/Typography.xaml" />
                <ResourceDictionary Source="Styles/Controls.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />
            <conv:NullToVisibilityConverter x:Key="NullToVisibility" />
            <conv:CountToVisibilityConverter x:Key="CountToVisibility" />
            <conv:IntToBoolConverter x:Key="IntToBool" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
